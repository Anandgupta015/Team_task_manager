.env
.env.*
!.env.example

# Build output
dist/
build/

# Uploaded files
backend/uploads/

# Docker volumes / data
mongo_data/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
